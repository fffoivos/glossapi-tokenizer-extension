# Shared training config for the three bakeoff arms.
# Sourced by bakeoff_train.sbatch; do NOT execute directly.
#
# Every value below is sourced from one of:
#   [paper:§X p.Y] = Apertus tech report (arXiv:2509.14233) section / page
#   [sbatch:LNNN] = swiss-ai/pretrain-code pretraining/submit_apertus_8b.sh line
#   [code:path]   = swiss-ai/Megatron-LM code path
#   [v0.7:§X]     = our cpt_plan.md v0.7 section (CPT-specific divergence from pretraining)
#
# Closed: AdEMAMix everywhere (bakeoff + production); see TRAINING_RECIPE.md §2.

# --- Apertus base + Megatron-LM-Swiss-AI fork ---
APERTUS_BASE_HF="/iopsstor/scratch/cscs/fffoivos/models/apertus-8b-2509"
APERTUS_BASE_MEGATRON="/iopsstor/scratch/cscs/fffoivos/models/apertus-8b-2509-megatron"

# swiss-ai/Megatron-LM — main branch, HEAD as of 2026-05-20:
#   c92402e39ef3c8e69ea378a59e79059dc14541f4   [Agent A scan of github.com/swiss-ai/Megatron-LM]
# Apertus production does NOT pin a tag; default branch `main` is canonical. Pin our run.
MEGATRON_LM_SWISSAI_DIR="/iopsstor/scratch/cscs/fffoivos/code/training/Megatron-LM-Swiss-AI"
MEGATRON_LM_SWISSAI_COMMIT="c92402e39ef3c8e69ea378a59e79059dc14541f4"

# --- AdEMAMix hyperparameters (Apertus pretraining values) ---
# All values verified against paper Table C.4 (p.82) + submit_apertus_8b.sh lines 207-213.
ADEMA_BETA1="0.9"              # [paper:§C Table C.4] [sbatch:L208 --adam-beta1]
ADEMA_BETA2="0.999"            # [paper:§C Table C.4] [sbatch:L209 --adam-beta2]
ADEMA_BETA3="0.9999"           # [paper:§C Table C.4] [sbatch:L211 --ademamix-beta3]
ADEMA_ALPHA="8.0"              # [paper:§C Table C.4] [sbatch:L210 --ademamix-alpha]
ADEMA_WEIGHT_DECAY="0.1"       # [paper:§C Table C.4] [sbatch:L207 --weight-decay]

# β3 + α warmup: Apertus pretraining used 100,000 steps for both, applied
# "before the first checkpoint of WSD" [paper:§C p.81]. For our CPT we adopt
# the conservative cold-restart policy (per AdEMAMix paper §"Switching optimizers"):
# warmup over the full bakeoff horizon so the slow EMA isn't artificially shocked.
#
# Apertus's 100k steps ÷ 3.66B samples / sample_per_step = ~2.8% of run was warmup.
# At 2B-token bakeoff (~477 steps), 2.8% = ~14 steps — too short to be meaningful.
# We use 50% of bakeoff length = ~238 steps for both warmups. Production CPT
# (15-20B tokens, ~3,500-4,800 steps) scales back to 2.8% = ~100-140 steps.
# Reviewer note: this is intentionally a heavy bakeoff warmup fraction relative
# to Apertus; production CPT should scale back to the Apertus-like ~2.8%.
# NOTE: actual Megatron CLI flag names are `--ademamix-beta3-warmup` /
# `--ademamix-alpha-warmup` (NOT `--ademamix-beta3-warmup-steps` etc.).
# Verified against: submit_apertus_8b.sh L218-219 + ademamix.py::__init__(beta3_warmup=…, alpha_warmup=…).
ADEMA_BETA3_WARMUP_STEPS="${ADEMA_BETA3_WARMUP_STEPS:-238}" # [v0.7 deviation: bakeoff scales 100k -> 50% of 477-step horizon]
ADEMA_ALPHA_WARMUP_STEPS="${ADEMA_ALPHA_WARMUP_STEPS:-238}" # [v0.7 deviation: bakeoff scales 100k -> 50% of 477-step horizon]
ADEMA_BETA_START="$ADEMA_BETA1" # paper: β_start = β1 for the β3 log-form schedule (ademamix.py L117)

# --- Initialization std (preserved from Apertus) ---
INIT_STD="0.008944"            # [paper:§C Table C.4] [sbatch:L235 --init-method-std]

# --- LR schedule (WSD with 1-sqrt cooldown) ---
# Apertus pretraining: peak 1.1e-4, min 1.1e-5, warmup 16.78 BT linear from 0.1× peak,
# stable until 13.5T, then 1-sqrt cooldown over 1.5T → 15T total.
#   [paper:§2.3 p.12; Table C.4 p.82] [sbatch:L237-247]
#
# Our CPT divergence: peak LR is lowered (1.5e-5, ≪ pretrain 1.1e-4) since we
# operate near-converged.  [v0.7:§3.3]
LR_PEAK="1.5e-5"               # [v0.7:§3.3]  (CPT peak; Apertus pretrain used 1.1e-4)
LR_FINAL="1.5e-6"              # = 0.1 × LR_PEAK, matching Apertus's "factor of 0.1" pattern
LR_WARMUP_TOKENS="${LR_WARMUP_TOKENS:-40000000}" # ≈ 2% of 2B-token bakeoff (re-warm from low -> peak)
LR_DECAY_STYLE="1-sqrt"        # [paper:§2.3; Table C.4 "LR WSD Decay Style 1-sqrt"] [sbatch:L242 --lr-wsd-decay-style 1-sqrt]

# --- Global gradient clipping ---
GRAD_CLIP="0.1"                # [paper:§C Table C.4] [sbatch:L207 --clip-grad 0.1]

# --- Sequence + batch shape ---
SEQ_LENGTH="4096"              # [paper:Table 2 p.10] [sbatch:L218 SEQ_LEN=4096]
# Apertus initial global batch = 1024 × 4096 = 4.19M tokens; ramped to 2048 × 4096 = 8.39M
# after 8T tokens.  [paper:§2.3]
# For the 2B-token bakeoff we use the initial Apertus shape (1024 global batch).
MICROBATCH_SIZE="2"            # [CPT-DIFF: GH200 memory margin after TP=2; Apertus used 4]
GLOBAL_BATCH_SIZE="1024"       # in samples; tokens = 1024 × 4096 = 4,194,304
GLOBAL_BATCH_TOKENS="4194304"  # = GLOBAL_BATCH_SIZE × SEQ_LENGTH
# grad_accum is derived inside Megatron from data-parallel world size.
# Global batch tokens are preserved at 4.19M; only grad-accum count changes
# (Apertus mb=4 -> 128 microbatches; us mb=2 -> 256 microbatches). The loss
# objective per optimizer step is the same; bf16 numerical accumulation order
# differs but is internally consistent across all three bakeoff arms.
# TP=2 matches Apertus pretraining and avoids the TP=1 OOM where each GH200 had
# to hold the full 8B training state.

# --- Loss objective ---
LOSS_OBJECTIVE="${LOSS_OBJECTIVE:-ntp}" # [v0.7:§10 Q B4 — NTP for bakeoff; Goldfish for production]
# Metric policy: Megatron's raw `lm loss` is per-target-token CE and is not
# cross-tokenizer fair across the base 131,072-token arm and 148,480-token
# extended arms. It is health/within-arm telemetry. Selection uses heldout
# BPC/BPB from `compute_tokenizer_fair_metrics.py`. Once the Megatron logging
# patch is active, dense `bpb`/`bpt` plus `base_loss`/`new_loss`/`n_new` should
# be read as measurement-only fields computed over the same loss-mask positions
# as this objective, including Goldfish-masked positions in production.
# Apertus's Goldfish config (production-only — included for documentation):
GOLDFISH_K="50"                # [paper:§2.3 p.11; Table C.4] [sbatch:--goldfish-k 50]
GOLDFISH_H="50"                # [paper:§2.3 p.11; Table C.4] [sbatch:--goldfish-h 50]
# Hash function: deterministic precomputed table of size 1,000,003 seeded 2971215073.
# Impl: megatron/core/datasets/gpt_dataset.py apply_goldfish at L741.

# --- Document boundary handling ---
# Cross-doc attention masking: ON.  [paper:§2.1 p.10] [sbatch:L286-289]
# EoD loss masking: ON.  [paper:§2.1] [sbatch:--eod-mask-loss]
CROSS_DOC_ATTN_FLAGS="--reset-attention-mask --reset-position-ids"
EOD_LOSS_MASK_FLAG="--eod-mask-loss"

# --- Mixed precision ---
# bf16 throughout, fp32 master grads. FP8 was tried at 8T tokens, caused
# loss degradation, rolled back. [paper:Appendix D p.83] [sbatch:L184, L255]
MIXED_PRECISION_FLAG="--bf16"
MAIN_GRADS_DTYPE="fp32"

# --- Activation + attention ---
# xIELU with αp_init = αn_init = 0.8 (β = 0.5). Paper §2.1 p.10 names xIELU;
# the numeric init is in code only (megatron/training/activations.py:XIELU.__init__
# defaults; stored as inverse-softplus so F.softplus(.) recovers 0.8 at step 0).
# Confirmed flag name: `--xielu` (NOT `--xielu-activation`).
#   [submit_apertus_8b.sh L195]
ACTIVATION_FLAG="--xielu"
XIELU_INIT_AP="0.8"            # [code: megatron/training/activations.py:XIELU.__init__ default alpha_p_init=0.8]
XIELU_INIT_AN="0.8"            # [code: megatron/training/activations.py:XIELU.__init__ default alpha_n_init=0.8]

# QK-Norm: RMSNorm, per-head, applied BEFORE RoPE.
#   [paper:§2.1 p.9 "We replace LayerNorm with RMSNorm"]
#   [code: megatron/core/transformer/attention.py L652-656 (norm before),
#          L432 (RoPE after)]
#   [sbatch:L192 --qk-layernorm --qknorm-impl apex --normalization RMSNorm]
QK_LAYERNORM_FLAG="--qk-layernorm"
QKNORM_IMPL="apex"
NORMALIZATION="RMSNorm"

# --- Tokenizer paths (per arm) ---
# Vanilla trains on the BASE 131,072 Apertus vocab (control arm — answers
# "does extension justify its parameter cost?"). ReTok and Centroid train on
# the EXTENDED 148,480 vocab. Two separately-preprocessed Megatron binary
# datasets are required — Vanilla's data tokenized with the base tokenizer,
# extended arms' data tokenized with the 148,480 ship bundle. Mixing them
# (training Vanilla on a 148,480-tokenized binary) would produce out-of-range
# token IDs for Vanilla's [0, 131,072) embedding table.
# This is reviewer round-2 Blocker 2.
BASE_TOKENIZER_DIR="/iopsstor/scratch/cscs/fffoivos/models/apertus-8b-2509"
EXT_TOKENIZER_DIR="/iopsstor/scratch/cscs/fffoivos/tokenizers/apertus_greek_modern_only_148480"

# --- Dataloader / data (per arm) ---
# Built by two separate preprocess_data.sbatch invocations:
#   sbatch --export=ALL,TOKENIZER_DIR=$BASE_TOKENIZER_DIR,OUTPUT_PREFIX=$BASE_DATA_PREFIX preprocess_data.sbatch
#   sbatch --export=ALL,TOKENIZER_DIR=$EXT_TOKENIZER_DIR,OUTPUT_PREFIX=$EXT_DATA_PREFIX  preprocess_data.sbatch
BASE_DATA_PREFIX="${BASE_DATA_PREFIX:-/iopsstor/scratch/cscs/fffoivos/cpt_corpus/bulk_mix_base_megatron/bulk_mix_text_document}"
EXT_DATA_PREFIX="${EXT_DATA_PREFIX:-/iopsstor/scratch/cscs/fffoivos/cpt_corpus/bulk_mix_ext_megatron/bulk_mix_text_document}"

DATA_SEED="${DATA_SEED:-20260520}" # shared JSONL text stream across all three arms
DATALOADER_WORKERS="${DATALOADER_WORKERS:-4}"

# --- Checkpoint cadence ---
SAVE_INTERVAL="${SAVE_INTERVAL:-65}" # ≈ every 250M tokens at 4M/step
EVAL_INTERVAL="${EVAL_INTERVAL:-25}" # ≈ every 100M tokens at 4M/step (trajectory metrics)
EXIT_INTERVAL="${EXIT_INTERVAL:-}"   # optional smoke-only clean exit after N iterations
RESUME_TRAINING="${RESUME_TRAINING:-0}" # 0 = init ckpt/no optimizer; 1 = resume own train ckpt
DISABLE_SAVE="${DISABLE_SAVE:-0}" # smoke-only escape hatch; keeps normal training checkpointing unchanged

# --- Training budget ---
TRAIN_TOKENS="${TRAIN_TOKENS:-2000000000}" # 2B per arm (bakeoff)  [v0.7:§5]
TRAIN_SAMPLES="$(( TRAIN_TOKENS / SEQ_LENGTH ))"
TRAIN_ITERS="$(( TRAIN_SAMPLES / GLOBAL_BATCH_SIZE ))"  # ≈ 477 iterations

# --- Parallelism / Slurm shape ---
TENSOR_MODEL_PARALLEL_SIZE="2" # [sbatch:L270] Apertus pretraining value; required for GH200 memory
PIPELINE_MODEL_PARALLEL_SIZE="1"
PARTITION="${PARTITION:-normal}"
TIME_LIMIT="${TIME_LIMIT:-12:00:00}"
NODES="${NODES:-1}"
GPUS_PER_NODE="${GPUS_PER_NODE:-4}"
LAUNCH_MODE="${LAUNCH_MODE:-}"
if [ -z "$LAUNCH_MODE" ]; then
    if [ "$NODES" -gt 1 ]; then
        # Clariden multi-node PyTorch was validated with one Slurm task per
        # node launching torchrun --nproc_per_node=$GPUS_PER_NODE. Direct
        # 8-task Slurm launch hit inter-node NCCL errors before iteration 1.
        LAUNCH_MODE="torchrun"
    else
        LAUNCH_MODE="slurm"
    fi
fi
ACCOUNT="${ACCOUNT:-a0140}"
# v2.6.0 trains through first iterations but lacks
# torch.distributed.checkpoint.filesystem.SerializationFormat, which Megatron's
# torch_dist save path imports. v2.9.1:v2 keeps the training stack usable and
# makes checkpoint writes possible.
UENV_IMAGE="${UENV_IMAGE:-pytorch/v2.9.1:v2}"

# End of common config.
